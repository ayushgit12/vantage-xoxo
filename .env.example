# ──────────────────────── Azure ────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=vantage-rg
AZURE_LOCATION=eastus

# ──────────────────────── Cosmos DB ────────────────────
COSMOS_CONNECTION_STRING=
COSMOS_DATABASE_NAME=vantage

# ──────────────────────── Azure Blob Storage ───────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=vantage-files

# ──────────────────────── Azure Service Bus ────────────
SERVICE_BUS_CONNECTION_STRING=
SERVICE_BUS_QUEUE_RETRIEVER=retriever-jobs
SERVICE_BUS_QUEUE_PLANNER=planner-jobs
SERVICE_BUS_QUEUE_EXECUTOR=executor-jobs

# ──────────────────────── Azure OpenAI ─────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-06-01

# ──────────────────────── Microsoft Graph ──────────────
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
GRAPH_REDIRECT_URI=http://localhost:8000/auth/callback

# ──────────────────────── App Insights ─────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ──────────────────────── App Config ───────────────────
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO
ENVIRONMENT=development

# ──────────────────────── Auth ─────────────────────────
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# ──────────────────────── Calendar Mock ────────────────
USE_MOCK_CALENDAR=true
